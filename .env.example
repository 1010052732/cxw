# 高德地图 Web 端 Key（https://console.amap.com/dev/key/app）
# 仓库已包含 .env（含 Key），克隆后 npm install && npm run dev 即可
VITE_AMAP_KEY=your_amap_web_key

# 安全密钥 securityJsCode（与 Key 配对，须在加载脚本前注入）
VITE_AMAP_SECURITY_CODE=your_security_js_code

# 后端 API 根路径（留空则使用本地 Mock 融合数据）
VITE_API_BASE=

# 设为 false 且配置 VITE_API_BASE 后将请求 /analysis/market/geo
VITE_USE_MOCK=true
